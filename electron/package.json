{
  "name": "job-tracker",
  "version": "1.0.0",
  "description": "Job Application Tracker - Controla tus postulaciones de trabajo",
  "main": "main.js",
  "author": "Luis",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.luis.jobtracker",
    "productName": "Job Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "JobTracker-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Job Tracker"
    }
  }
}
